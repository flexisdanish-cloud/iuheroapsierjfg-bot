<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Complete Payment</title>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        body {
            font-family: Arial, sans-serif;
        }
    </style>
</head>

<body class="bg-gray-100 flex justify-center items-center min-h-screen">

    <div class="bg-white w-[95%] max-w-md p-6 sm:p-8 rounded-xl shadow-lg text-center">

        <h2 class="text-2xl font-bold mb-4">
            🌿 Premium Plan
        </h2>

        <p class="text-gray-600 mb-6">
            <span class="text-3xl font-bold">₹500</span>
            / month
        </p>

        <button id="payBtn"
            onclick="pay()"
            class="w-full bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-xl text-lg transition">
            Pay ₹500
        </button>

        <div class="space-y-3 mt-6">

            <p class="font-semibold text-lg text-center">
                Premium Benefits
            </p>

            <ul class="list-disc list-inside text-left text-gray-700 space-y-1">
                <li>Hair Growth Oil Recipe</li>
                <li>Complete Hair Care Routine</li>
                <li>Premium PDF Guide</li>
                <li>Telegram Access</li>
            </ul>

        </div>

    </div>

    <script>

        let statusInterval;
        let attempts = 0;

        function pay() {

            const btn = document.getElementById("payBtn");
            btn.disabled = true;
            btn.innerText = "Opening Payment...";

            let options = {

                key: "<%= razorpayKey %>",

                amount: 50000,

                currency: "INR",

                name: "Premium Plan",

                description: "Telegram Purchase",

                order_id: "<%= orderId %>",

                handler: function (response) {

                    console.log("Payment Response:", response);

                    fetch("/verify-payment", {

                        method: "POST",

                        headers: {
                            "Content-Type": "application/json"
                        },

                        body: JSON.stringify(response)

                    })
                        .then(res => res.json())
                        .then(data => {

                            if (!data.success) {
                                alert("Payment verification failed.");
                                btn.disabled = false;
                                btn.innerText = "Pay ₹500";
                                return;
                            }

                            document.body.innerHTML = `
                            
                            <div class="flex justify-center items-center min-h-screen bg-gray-100">
                                <div class="bg-white p-8 rounded-xl shadow-lg text-center">
                                    <h2 class="text-2xl font-bold mb-3">
                                        ⏳ Payment Processing
                                    </h2>
                                    <p class="text-gray-600">
                                        Waiting for payment confirmation...
                                    </p>
                                </div>
                            </div>

                            `;

                            checkPaymentStatus();

                        })
                        .catch(err => {

                            console.error(err);
                            alert("Server error while verifying payment.");

                            btn.disabled = false;
                            btn.innerText = "Pay ₹500";

                        });

                },

                prefill: {

                    name: "Telegram User"

                },

                theme: {

                    color: "#16a34a"

                },

                modal: {

                    ondismiss: function () {

                        btn.disabled = false;
                        btn.innerText = "Pay ₹500";

                        console.log("Payment window closed");

                    }

                }

            };

            let rzp = new Razorpay(options);

            rzp.on("payment.failed", function (response) {

                console.log(response.error);

                alert("Payment failed.");

                btn.disabled = false;
                btn.innerText = "Pay ₹500";

            });

            rzp.open();

        }

        function checkPaymentStatus() {

            attempts = 0;

            statusInterval = setInterval(() => {

                attempts++;

                if (attempts >= 20) {

                    clearInterval(statusInterval);

                    alert("Payment confirmation is taking longer than expected.");

                    return;

                }

                fetch("/payment-status/<%= orderId %>")

                    .then(res => res.json())

                    .then(data => {

                        console.log("Payment Status:", data.status);

                        if (data.status === "paid") {

                            clearInterval(statusInterval);

                            window.location = "/success/<%= orderId %>";

                        }

                        if (data.status === "failed") {

                            clearInterval(statusInterval);

                            alert("Payment failed.");

                        }

                    })

                    .catch(err => {

                        console.error(err);

                    });

            }, 3000);

        }

    </script>

</body>

</html>